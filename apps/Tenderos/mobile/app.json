{
  "expo": {
    "name": "Tenderos Mobile",
    "slug": "tenderos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "tenderosmobile",
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "updates": {
      "enabled": false,
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
