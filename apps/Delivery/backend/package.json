{
  "name": "delivery-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @repo/api-contracts build && pnpm --filter @repo/backend-core build && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check-types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@repo/api-contracts": "workspace:^",
    "@repo/backend-core": "workspace:*",
    "express": "^4.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.3",
    "nodemon": "^3.1.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
